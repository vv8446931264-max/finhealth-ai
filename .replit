modules = ["nodejs-20"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "static"
publicDir = "dist"
build = ["npm", "run", "build"]

[[ports]]
localPort = 4173
externalPort = 80

[workflows]
runButton = "Build & Preview"

[[workflows.workflow]]
name = "Build & Preview"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && npm run build && npm run preview -- --port 4173 --host 0.0.0.0"
